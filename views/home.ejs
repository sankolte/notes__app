<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Notes App</title>
    <link rel="stylesheet" href="/home.css">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
</head>
<body>

    <nav class="navbar">
        <div class="nav-brand">
            <h1>📝Write<span>App</span></h1>
        </div>
        <div class="nav-controls">
            <% if (!currUser) { %>
                <a href="/users/signup" class="btn-glow">Sign Up</a>
                <a href="/users/login" class="btn-outline">Log In</a>
            <% } else { %>
                <span class="user-greeting">Hey, <span class="highlight"><%= currUser.username %></span> ✨</span>
                <form action="/users/logout" method="GET" style="display:inline;">
                    <button type="submit" class="btn-logout"><span class="material-icons">logout</span></button>
                </form>
            <% } %>
        </div>
    </nav>

    <header class="hero">
        <h2>Capture Your Thoughts</h2>
        <p>Make your day incredibly productive by organizing your ideas.</p>
        
        <div class="hero-action">
            <a href="/notes/new" class="btn-glow">
                <span class="material-icons">add_box</span> Create Note
            </a>
        </div>

        <% if (currUser) { %>
            <div class="search-container">
                <form action="/notes" method="GET" class="search-bar">
                    <span class="material-icons search-icon">search</span>
                    <input type="text" name="q" placeholder="Search ideas..." value="<%= locals.searchQuery || '' %>" autocomplete="off">
                </form>
            </div>
        <% } %>
    </header>

    <main class="container">

        <% if (notes.length === 0) { %>
            <% if (locals.searchQuery) { %>
                <p class="empty">No notes match your search "<%= locals.searchQuery %>".</p>
            <% } else { %>
                <p class="empty">No notes yet. Start writing ✨</p>
            <% } %>
        <% } %>

        <div class="notes-grid">
            <% for(let i = 0; i < notes.length; i++) { %>
                <div class="note-card <%= notes[i].isImportant ? 'important' : '' %>">
                    <a href="/notes/<%=notes[i]._id%>/view" class="note-link">
                        <h3><%= notes[i].title %></h3>
                        <p class="content"><%= notes[i].content %></p>
                    </a>
                   <form method="GET" action="/notes/<%=notes[i]._id %>/edit">
                    <button>edit</button>
                   </form>
                   <form method="POST" action="/notes/delete/<%= notes[i]._id %>?_method=DELETE"><button>Delete</button></form>
                   <p class="author">By: <%= notes[i].user ? notes[i].user.username : 'Unknown' %></p>
                    <div class="meta">
                        <span><%= notes[i].createdAt.toDateString() %></span>
                        <% if (notes[i].isImportant) { %>
                            <span class="badge">Important</span>
                        <% } %>
                    </div>
                </div>
            <% } %>
        </div>

    </main>

</body>
</html>

